pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
    }

    stages {
        stage('Start Alpine Container') {
            steps {
                echo "Starting temporary Alpine container..."
                sh '''
                    docker rm -f jenkins-destroy || true
                    docker run -d --name jenkins-destroy \
                        -v $PWD:/workspace \
                        -w /workspace \
                        alpine:3.19 tail -f /dev/null
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    docker exec jenkins-destroy sh -c "
                        apk add --no-cache git bash curl unzip &&
                        cd /tmp &&
                        curl -LO https://releases.hashicorp.com/terraform/1.6.6/terraform_1.6.6_linux_amd64.zip &&
                        unzip -o terraform_1.6.6_linux_amd64.zip &&
                        mv terraform /usr/local/bin/ &&
                        terraform version
                    "
                '''
            }
        }

        stage('Checkout') {
            steps {
                echo "Checking out code from GitHub..."
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'JENKINS_SERVER_SSH_PUBLIC_KEY', variable: 'JENKINS_SERVER_SSH_PUBLIC_KEY')
                ]) {
                    sh '''
                        docker exec \
                        -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                        -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                        -e JENKINS_SERVER_SSH_PUBLIC_KEY="$JENKINS_SERVER_SSH_PUBLIC_KEY" \
                        jenkins-destroy sh -c "
                            cd terraform/03-ecommerce-cluster &&
                            terraform init -var 'jenkins_public_key=$JENKINS_SERVER_SSH_PUBLIC_KEY'
                        "
                    '''
                }
            }
        }

        stage('Terraform Destroy') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'JENKINS_SERVER_SSH_PUBLIC_KEY', variable: 'JENKINS_SERVER_SSH_PUBLIC_KEY')
                ]) {
                    sh '''
                        docker exec \
                        -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                        -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                        -e JENKINS_SERVER_SSH_PUBLIC_KEY="$JENKINS_SERVER_SSH_PUBLIC_KEY" \
                        jenkins-destroy sh -c "
                            cd terraform/03-ecommerce-cluster &&
                            terraform destroy -auto-approve -var 'jenkins_public_key=$JENKINS_SERVER_SSH_PUBLIC_KEY'
                        "
                    '''
                }
            }
        }

        stage('Cleanup Container') {
            steps {
                echo "Stopping and removing temporary container..."
                sh '''
                    docker stop jenkins-destroy
                    docker rm jenkins-destroy
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Terraform infrastructure destroyed successfully!"
        }
        failure {
            echo "Failed to destroy Terraform infrastructure!"
        }
    }
}