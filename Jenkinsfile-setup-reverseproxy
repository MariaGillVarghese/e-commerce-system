pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        PROJECT_DIR           = 'terraform/02-reverseproxy-server'
    }

    stages {
        stage('Start Alpine Container') {
            steps {
                sh '''
                    docker rm -f jenkins-proxy-build || true
                    docker run -d --name jenkins-proxy-build \
                        -v $PWD:/workspace \
                        -w /workspace \
                        alpine:3.19 tail -f /dev/null
                '''
            }
        }

        stage('Install Terraform') {
            steps {
                sh '''
                docker exec jenkins-proxy-build sh -c "
                    apk add --no-cache git bash curl unzip &&
                    cd /tmp &&
                    curl -LO https://releases.hashicorp.com/terraform/1.6.6/terraform_1.6.6_linux_amd64.zip &&
                    unzip -o terraform_1.6.6_linux_amd64.zip &&
                    mv terraform /usr/local/bin/
                "
                '''
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([
                    string(credentialsId: 'JENKINS_SERVER_SSH_PUBLIC_KEY', variable: 'JENKINS_PUB_KEY')
                ]) {
                    sh """
                        docker exec \
                        -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                        -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                        jenkins-proxy-build sh -c "
                            cd ${PROJECT_DIR} &&
                            terraform init
                        "
                    """
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                withCredentials([
                    string(credentialsId: 'JENKINS_SERVER_SSH_PUBLIC_KEY', variable: 'JENKINS_PUB_KEY')
                ]) {
                    sh """
                        docker exec \
                        -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                        -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                        -e JENKINS_PUB_KEY='${JENKINS_PUB_KEY}' \
                        jenkins-proxy-build sh -c "
                            cd ${PROJECT_DIR} &&
                            terraform plan -out=tfplan -var 'jenkins_public_key=\$JENKINS_PUB_KEY'
                        "
                    """
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'JENKINS_SERVER_SSH_PUBLIC_KEY', variable: 'JENKINS_PUB_KEY')
                ]) {
                    sh """
                        docker exec \
                        -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                        -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                        -e JENKINS_PUB_KEY='${JENKINS_PUB_KEY}' \
                        jenkins-proxy-build sh -c "
                            cd ${PROJECT_DIR} &&
                            terraform apply -auto-approve tfplan
                        "
                    """
                }
            }
        }

        stage('Cleanup Container') {
            steps {
                sh 'docker rm -f jenkins-proxy-build || true'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}