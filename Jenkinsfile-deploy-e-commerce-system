pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
    }
    
    options {
        skipDefaultCheckout()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out code from GitHub..."
                checkout scm
            }
        }

        stage('Start Ansible Container') {
            steps {
                echo "Starting temporary container for Ansible..."
                sh '''
                    docker rm -f ansible-build || true
                    docker run -d --name ansible-build \
                    -v /var/lib/jenkins/workspace/setup-e-commerce-system:/workspace \
                    -v /home/maria/.ssh:/root/.ssh:ro \
                    -w /workspace \
                    ubuntu:22.04 tail -f /dev/null
                    docker exec ansible-build sh -c "chmod 600 /root/.ssh/id_rsa"
                    docker exec ansible-build sh -c "cat /root/.ssh/id_rsa"
                '''
            }
        }

        stage('Install Ansible & Dependencies') {
            steps {
                sh '''
                    docker exec ansible-build sh -c "
                        apt-get update && \
                        DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip sshpass git && \
                        pip3 install --upgrade pip && \
                        pip3 install ansible
                    "
                '''
            }
        }

        stage('Run Ansible Playbook') {
            steps {
                dir('ansible/') {
                    echo "Checking files inside container..."
                    sh '''
                        docker exec ansible-build sh -c "
                            ls -R /workspace
                        "
                    '''

                    echo "Running Ansible playbook..."
                    sh '''
                        docker exec ansible-build sh -c "
                            ansible-playbook -i /workspace/ansible/production/company/inventory.ini \
                                            /workspace/ansible/production/company/playbook.yml
                        "
                    '''
                }
            }
        }

        stage('Cleanup Container') {
            steps {
                echo "Stopping and removing temporary container..."
                sh '''
                    docker stop ansible-build
                    docker rm ansible-build
                '''
            }
        }
    }

    post {
        always {
            echo "Cleaning up workspace..."
            cleanWs()
        }
        success {
            echo "DB and E-Commerce-System deployed successfully!"
        }
        failure {
            echo "Deployment failed!"
        }
    }
}