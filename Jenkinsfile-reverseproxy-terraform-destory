pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        PROJECT_DIR           = 'terraform/02-reverseproxy-server'
        CONTAINER_NAME        = "jenkins-proxy-destroy-${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Confirm Destruction') {
            steps {
                input message: "Are you sure you want to DESTROY the Reverse Proxy resources?", ok: "Yes, Destroy"
            }
        }

        stage('Start Alpine Container') {
            steps {
                sh """
                    docker rm -f ${CONTAINER_NAME} || true
                    docker run -d --name ${CONTAINER_NAME} \
                        -v ${WORKSPACE}:/workspace \
                        -w /workspace \
                        alpine:3.19 tail -f /dev/null
                """
            }
        }

        stage('Install Terraform') {
            steps {
                sh """
                docker exec ${CONTAINER_NAME} sh -c "
                    apk add --no-cache git bash curl unzip &&
                    cd /tmp &&
                    curl -LO https://releases.hashicorp.com/terraform/1.6.6/terraform_1.6.6_linux_amd64.zip &&
                    unzip -o terraform_1.6.6_linux_amd64.zip &&
                    mv terraform /usr/local/bin/
                "
                """
            }
        }

        stage('Terraform Init') {
            steps {
                sh """
                    docker exec \
                    -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                    -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                    ${CONTAINER_NAME} sh -c "
                        cd ${PROJECT_DIR} &&
                        terraform init
                    "
                """
            }
        }

        stage('Terraform Destroy') {
            steps {
                withCredentials([
                    string(credentialsId: 'JENKINS_SERVER_SSH_PUBLIC_KEY', variable: 'JENKINS_PUB_KEY')
                ]) {
                    sh """
                        docker exec \
                        -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
                        -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
                        -e JENKINS_PUB_KEY='${JENKINS_PUB_KEY}' \
                        ${CONTAINER_NAME} sh -c "
                            cd ${PROJECT_DIR} &&
                            terraform destroy -auto-approve -var 'jenkins_public_key=\$JENKINS_PUB_KEY'
                        "
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning up container and workspace..."
            sh "docker rm -f ${CONTAINER_NAME} || true"
            cleanWs()
        }
        success {
            echo "Reverse Proxy resources destroyed successfully."
        }
    }
}